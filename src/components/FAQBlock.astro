---
export interface FAQItem {
  q: string;
  a: string;
}

interface Props {
  items: FAQItem[];
  heading?: string;
}

const { items, heading = 'Frequently Asked Questions' } = Astro.props;

const faqSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": items.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.a,
    },
  })),
});
---

<script type="application/ld+json" set:html={faqSchema}></script>

<section class="section-sm">
  <div class="container">
    <h2>{heading}</h2>
    <div class="faq-list" role="list">
      {items.map((item, i) => (
        <details class="faq-item" role="listitem">
          <summary class="faq-question">
            <span>{item.q}</span>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
              <path d="M8 10.94L1.53 4.47l1.06-1.06L8 8.82l5.41-5.41 1.06 1.06z"/>
            </svg>
          </summary>
          <div class="faq-answer">
            <p set:html={item.a}></p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
