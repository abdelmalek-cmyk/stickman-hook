---
import BaseLayout from '@/layouts/BaseLayout.astro';
import GameEmbed from '@/components/GameEmbed.astro';
import FAQBlock from '@/components/FAQBlock.astro';
import { SITE } from '@/consts';
import { GAMES } from '@/data/games';

const title = 'Stickman Hook – Play the Original Game Online Free';
const description = 'Play Stickman Hook online free. Swing through 100+ levels with your grappling hook — no download, instant play in your browser.';

const videoGameSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "VideoGame",
  "name": "Stickman Hook",
  "description": "Physics-based swinging game where you control a stickman using a grappling hook to swing from anchor to anchor and reach the finish line.",
  "genre": "Arcade",
  "gamePlatform": ["Web browser", "iOS", "Android"],
  "author": { "@type": "Organization", "name": "Madbox" },
  "publisher": { "@type": "Organization", "name": "Madbox" },
  "datePublished": SITE.releaseDate,
  "applicationCategory": "Game",
  "operatingSystem": ["Web", "iOS", "Android"],
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "GBP" },
  "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.3", "bestRating": "5", "worstRating": "1", "ratingCount": "1000000" },
  "url": SITE.url,
  "image": `${SITE.url}/og/home.png`,
  "sameAs": [SITE.appStoreUrl, SITE.googlePlayUrl],
});

const faqItems = [
  {
    q: 'What is Stickman Hook?',
    a: 'Stickman Hook is a free physics-based swinging game by Madbox. You control a stickman who uses a grappling hook to swing from anchor to anchor, building momentum to fly across each level and reach the finish line. It launched in October 2018 and plays in any browser or as a mobile app.',
  },
  {
    q: 'Is Stickman Hook free to play?',
    a: 'Yes, Stickman Hook is completely free to play in your browser and free to download on iOS and Android. It\'s ad-supported, with optional in-app purchases such as a "No Ads" upgrade, but you can complete every level without spending anything.',
  },
  {
    q: 'How many levels are in Stickman Hook?',
    a: 'Stickman Hook has over 100 levels in the browser version, with difficulty rising sharply after level 50. The mobile app includes 1,000+ levels and Madbox keeps adding more — there\'s no fixed last level.',
  },
  {
    q: 'Can I play Stickman Hook without downloading anything?',
    a: 'Yes — the browser version runs entirely in HTML5, so there\'s nothing to install. Just click Play above and start swinging immediately. The game works on desktop browsers, Chromebooks, and most mobile browsers.',
  },
  {
    q: 'Who made Stickman Hook?',
    a: 'Stickman Hook was developed and published by Madbox, a France-based mobile game studio. It was first released on iOS on 3 October 2018 and has since passed 100 million downloads on Google Play alone.',
  },
  {
    q: 'What is Grapple Hook mode?',
    a: 'Grapple Hook mode is an alternate game mode that unlocks after you complete 30 levels in Classic mode. It changes how the grappling mechanic feels and adds a new challenge for experienced players.',
  },
];
---

<style>
  /* ── More Games strip ── */
  .mg-section {
    background: var(--surface);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 1.5rem 0;
  }
  .mg-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }
  .mg-title {
    font-size: 1.05rem;
    font-weight: 800;
    color: var(--text);
    margin: 0;
  }
  .mg-see-all {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--accent-light);
    text-decoration: none;
    white-space: nowrap;
  }
  .mg-see-all:hover { text-decoration: underline; }

  /* Grid — 5 columns on desktop, wraps down to 3/2 */
  .mg-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(108px, 1fr));
    gap: 0.6rem;
  }

  /* Card */
  .mg-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
    text-decoration: none;
    color: inherit;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.06);
    background: #0d0d1a;
    transition: transform 0.15s, border-color 0.15s;
  }
  .mg-card:hover {
    transform: translateY(-3px);
    border-color: color-mix(in srgb, var(--gc) 55%, transparent);
    text-decoration: none;
  }

  /* Thumbnail area */
  .mg-thumb {
    width: 100%;
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    background: linear-gradient(145deg,
      color-mix(in srgb, var(--gc) 50%, #0d0d1a) 0%,
      #0a090e 100%
    );
    overflow: hidden;
  }
  .mg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .mg-emoji {
    font-size: 2.1rem;
    line-height: 1;
    position: relative;
    z-index: 1;
    filter: drop-shadow(0 2px 8px color-mix(in srgb, var(--gc) 60%, transparent));
  }

  /* HOT/category badge */
  .mg-badge {
    position: absolute;
    top: 4px;
    left: 4px;
    font-size: 0.52rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    background: color-mix(in srgb, var(--gc) 80%, #000);
    color: #fff;
    padding: 0.1rem 0.35rem;
    border-radius: 4px;
    z-index: 2;
    line-height: 1.4;
  }

  /* Name label */
  .mg-name {
    font-size: 0.67rem;
    font-weight: 700;
    color: var(--text-muted);
    text-align: center;
    padding: 0 0.4rem 0.45rem;
    line-height: 1.3;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    width: 100%;
  }
  .mg-card:hover .mg-name { color: var(--text); }

  @media (max-width: 480px) {
    .mg-grid { grid-template-columns: repeat(auto-fill, minmax(88px, 1fr)); gap: 0.5rem; }
  }
</style>

<BaseLayout title={title} description={description} schema={videoGameSchema}>
  <!-- Hero -->
  <div class="hero">
    <div class="container">
      <div class="hero-badge">Free Browser Game</div>
      <h1>Stickman Hook</h1>
      <p>Swing through 100+ levels using your grappling hook. No download — play instantly, free, in any browser.</p>
      <div class="hero-meta">
        <span>&#127381; Free to play</span>
        <span>&#128293; 100M+ downloads</span>
        <span>&#11088; 4.3 / 5 rating</span>
        <span>&#127381; By Madbox</span>
        <span>&#128540; Browser &amp; mobile</span>
      </div>
    </div>
  </div>

  <!-- Game embed -->
  <GameEmbed title="Play Stickman Hook" subtitle="Click to start swinging — free, no login" />

  <!-- Content -->
  <div class="section">
    <div class="container">

      <!-- Key facts -->
      <div class="facts-box">
        <h3>Quick Facts</h3>
        <div class="facts-grid">
          <div class="fact-item"><span class="fact-label">Developer</span><span class="fact-value">Madbox</span></div>
          <div class="fact-item"><span class="fact-label">Released</span><span class="fact-value">October 2018</span></div>
          <div class="fact-item"><span class="fact-label">Browser levels</span><span class="fact-value">100+</span></div>
          <div class="fact-item"><span class="fact-label">App levels</span><span class="fact-value">1,000+</span></div>
          <div class="fact-item"><span class="fact-label">Price</span><span class="fact-value">Free</span></div>
          <div class="fact-item"><span class="fact-label">Age rating</span><span class="fact-value">4+</span></div>
          <div class="fact-item"><span class="fact-label">Platforms</span><span class="fact-value">Web, iOS, Android</span></div>
          <div class="fact-item"><span class="fact-label">Downloads</span><span class="fact-value">100M+</span></div>
        </div>
      </div>

      <div class="grid-2" style="gap:2rem;align-items:start;">
        <div>
          <h2>What is Stickman Hook?</h2>
          <p>Stickman Hook is a free physics-based swinging game by Madbox. You control a stickman who uses a grappling hook to swing from anchor to anchor, building momentum to fly across each level and reach the finish line. It launched in October 2018 and plays in any browser or as a mobile app.</p>
          <p>The game is deceptively simple: one button, infinite skill ceiling. Beginners can clear early levels in seconds, but mastering the timing of each release — swinging wide to carry momentum, cutting early to land on tight platforms — takes real practice. That contrast between easy-to-learn and hard-to-master is exactly what made Stickman Hook go viral.</p>
          <p>Madbox has grown the game steadily since launch. The browser version sits at 100+ curated levels across themed location groups, while the mobile app now includes 1,000+ stages and continues to receive new content. Both versions are completely free.</p>

          <h2>How do you play Stickman Hook?</h2>
          <p>Hold the left mouse button or spacebar on desktop (or tap and hold on mobile) to fire your grappling hook at the nearest anchor. Release to launch forward. Time your releases to keep momentum, use bounce pads to recover height, and swing to the finish line.</p>
          <div class="steps">
            <div class="step"><div class="step-num">1</div><p><strong>Hook:</strong> Hold mouse / spacebar / tap to attach your hook to the nearest glowing anchor point.</p></div>
            <div class="step"><div class="step-num">2</div><p><strong>Swing:</strong> Your stickman swings on the rope — lean into the arc to build speed.</p></div>
            <div class="step"><div class="step-num">3</div><p><strong>Launch:</strong> Release at the right moment to fly forward. Too early = fall short; too late = crash into the wall.</p></div>
          </div>

          <div class="tip-box">
            <p><strong>Pro tip:</strong> Release each swing slightly later than feels natural. Holding just a fraction longer gives you more forward momentum and stops you from losing height between hooks.</p>
          </div>
        </div>

        <div>
          <h2>Controls at a glance</h2>
          <table>
            <thead>
              <tr><th>Platform</th><th>Hook</th><th>Release</th></tr>
            </thead>
            <tbody>
              <tr><td>Desktop</td><td>Hold left mouse button or spacebar</td><td>Release button/key</td></tr>
              <tr><td>Mobile</td><td>Tap and hold screen</td><td>Lift finger</td></tr>
            </tbody>
          </table>

          <h2>Where can you play Stickman Hook?</h2>
          <p>You can play Stickman Hook free in your browser right here at stickman-hook.co.uk, or on portals like Poki and CoolMathGames. The official iOS and Android apps add offline play and 1,000+ levels. This site runs the full HTML5 browser version — no account, no download, no waiting.</p>

          <h2>Is Stickman Hook safe for kids?</h2>
          <p>Stickman Hook carries a 4+ age rating and contains no violence or mature content — just cartoon stickman swinging. It includes ads and optional in-app purchases in the mobile version, so parents may prefer supervised play or the ad-free upgrade for younger children. The browser version here is clean and kid-friendly.</p>

          <h2>What game modes does Stickman Hook have?</h2>
          <p>Stickman Hook has two main game modes. <strong>Classic mode</strong> is the default, taking you through progressively harder levels with fixed anchor points. <strong>Grapple Hook mode</strong> unlocks after completing 30 Classic levels and changes the swing physics for a fresh challenge. Both modes use the same one-button control scheme.</p>
        </div>
      </div>

      <!-- Internal links -->
      <h2 style="margin-top:2.5rem;">Explore Stickman Hook</h2>
      <div class="link-grid">
        <a href="/unblocked/" class="link-card">
          <strong>&#127891; Play Unblocked</strong>
          <span>Works at school &amp; on Chromebooks</span>
        </a>
        <a href="/how-to-play/" class="link-card">
          <strong>&#127919; How to Play</strong>
          <span>Controls, tips &amp; advanced tricks</span>
        </a>
        <a href="/levels/" class="link-card">
          <strong>&#127381; Levels Guide</strong>
          <span>How many levels &amp; walkthroughs</span>
        </a>
        <a href="/skins/" class="link-card">
          <strong>&#128084; Skins &amp; Characters</strong>
          <span>How to unlock every costume</span>
        </a>
        <a href="/stickman-hook-2/" class="link-card">
          <strong>&#9196; Stickman Hook 2</strong>
          <span>Sequel &amp; extended versions</span>
        </a>
        <a href="/faq/" class="link-card">
          <strong>&#10067; FAQ</strong>
          <span>Common questions answered</span>
        </a>
        <a href="/download/" class="link-card">
          <strong>&#128242; Download App</strong>
          <span>iOS &amp; Android — 1,000+ levels</span>
        </a>
        <a href="/games/" class="link-card">
          <strong>&#127918; More Games</strong>
          <span>Similar swing &amp; stickman games</span>
        </a>
      </div>
    </div>
  </div>

  <!-- Extended article content -->
  <div class="section" style="padding-top:0;padding-bottom:0;">
    <div class="container">
      <div class="grid-2" style="gap:2rem;align-items:start;margin-top:2.5rem;">
        <div>
          <h2>The history of Stickman Hook</h2>
          <p>Stickman Hook launched on iOS on 3 October 2018 and arrived on Android shortly after. Madbox, the Paris-based studio behind the game, built it around a single grappling hook mechanic — an intentional design constraint that forces players to master one skill rather than managing multiple controls at once. That deliberate simplicity turned out to be the game's greatest commercial and creative strength.</p>
          <p>Within months of launch, Stickman Hook had gone viral on social media, with players sharing satisfying swing chains and spectacular crashes. By 2020 it had crossed 50 million downloads; by 2022 it surpassed 100 million on Google Play alone, making it one of the most-downloaded casual games in history. The HTML5 browser version followed and quickly became one of the most-searched unblocked games on school networks worldwide — a testament to how well its simple mechanic works on any device and in any context.</p>

          <h2>Why Stickman Hook is so addictive</h2>
          <p>The game works because it hits several psychological engagement triggers simultaneously. The core loop — hook, swing, release, repeat — completes in under two seconds per cycle, meaning you can attempt corrections instantly without waiting through long animations or load screens. Failure is fast and cheap: you restart the level in under a second, removing the frustration barrier that makes many harder games feel punishing.</p>
          <p>The momentum system rewards skill in a visceral, immediate way. A perfect chain of swings carries a genuine kinetic satisfaction — you can feel the physics working in your favour. That tactile feedback, combined with a one-button constraint that makes every mistake your own fault rather than a control problem, creates an almost perfect mastery loop. Level 1 and level 80 use the exact same mechanic; the difference is entirely in timing precision, which makes progress feel earned.</p>
          <p>Madbox also designed the early levels to be completable in seconds, triggering repeated small rewards. Players routinely find they've spent 30 minutes without noticing, having restarted level 23 forty times in pursuit of a clean run.</p>

          <h2>Stickman Hook on PC vs mobile</h2>
          <p>The browser version and mobile app both use the same physics engine, but the experience differs in key ways. On PC, a mouse or keyboard provides precision but less tactile feedback. The browser version has 100+ curated levels, runs in a fixed window, and suits quick desk sessions — no download, no account, loads in seconds, works on school Chromebooks.</p>
          <p>On mobile, the touchscreen becomes the controller — tap and hold to hook, lift to release. The touch interface is arguably more natural for the mechanics, since your finger follows the arc of the swing. The mobile app includes 1,000+ levels, works offline once downloaded, has a larger skins catalogue, and includes ads between levels (removable via an optional upgrade). Neither version is strictly better; they serve different use cases. The browser game is for immediate, no-commitment play; the mobile app is for extended sessions and full progression.</p>
        </div>
        <div>
          <h2>How Stickman Hook compares to other browser games</h2>
          <p>Stickman Hook occupies a specific niche — physics-based one-button precision platformers — where it has no direct equal in the browser game space. The closest comparisons are Happy Wheels (player-created physics courses, far more complex controls), Run 3 (one or two inputs, but an endless runner rather than level-based swinging), the Vex series (parkour platformer with significantly more complex controls), and Doodle Jump (one-button but vertical and mobile-first).</p>
          <p>What sets Stickman Hook apart is the purity of its grappling hook mechanic. Every other physics browser game asks you to manage at least two inputs — move plus jump. Stickman Hook reduces mastery to a single decision: when to let go. This focus makes it uniquely accessible to people who don't consider themselves gamers, while still offering a skill ceiling deep enough to reward serious players with hundreds of hours of refinement.</p>

          <h2>Is Stickman Hook educational?</h2>
          <p>Several teachers and parents have noted that Stickman Hook naturally teaches applied physics: momentum, arc trajectories, timing, and cause-and-effect thinking. The game requires players to internalise the fact that objects in motion follow a predictable arc, and that releasing at different points produces different trajectories — core concepts covered in secondary school physics curricula.</p>
          <p>This is one practical reason why many school network filters don't flag it alongside other gaming content. It isn't marketed as educational software, but the underlying mechanics align with real physics principles, and the problem-solving required to clear later levels involves genuine spatial reasoning and pattern recognition. Many parents consider it one of the more cognitively engaging free games available in a browser.</p>

          <h2>Frequently asked questions about Stickman Hook</h2>
          <p><strong>Is Stickman Hook completely free?</strong> Yes — the browser version here is entirely free. The mobile app is also free to download, with optional ads removal and cosmetic skin packs available as in-app purchases. Every level can be completed without paying anything.</p>
          <p><strong>Does Stickman Hook save progress?</strong> In the browser version, progress is saved in your browser's local storage — closing the tab and reopening the page should resume where you left off, provided you don't clear your browser data. The mobile app has full cloud save through your App Store or Google Play account.</p>
          <p><strong>Can I play Stickman Hook with a friend?</strong> The official game is single-player. Madbox has not released an official multiplayer or co-op mode. Players do set up informal challenges (race to complete a level, fewest attempts), and some fan-made versions on platforms like Scratch include 2-player variants, but these are unofficial.</p>
          <p><strong>What browser is best for Stickman Hook?</strong> Google Chrome offers the best performance, followed by Firefox and Edge. Safari on macOS and iOS also works well. Avoid Internet Explorer; the game won't run on it. For the best experience, use the latest version of Chrome with hardware acceleration enabled (chrome://settings → System → Use hardware acceleration).</p>
        </div>
      </div>
    </div>
  </div>

  <!-- More Games thumbnail strip -->
  <div class="mg-section">
    <div class="container">
      <div class="mg-header">
        <h2 class="mg-title">🎮 More Free Games</h2>
        <a href="/games/" class="mg-see-all">See all 15 games →</a>
      </div>
      <div class="mg-grid">
        {GAMES.map((g) => (
          <a href={`/games/${g.slug}/`} class="mg-card" style={`--gc: ${g.color};`} title={g.title}>
            <div class="mg-thumb">
              {g.thumbnail
                ? <img class="mg-img" src={g.thumbnail} alt={g.title} loading="lazy" width="108" height="108" />
                : <span class="mg-emoji" aria-hidden="true">{g.emoji}</span>
              }
              <span class="mg-badge">{g.category}</span>
            </div>
            <span class="mg-name">{g.title}</span>
          </a>
        ))}
      </div>
    </div>
  </div>

  <!-- FAQ -->
  <FAQBlock items={faqItems} heading="Stickman Hook FAQ" />
</BaseLayout>
